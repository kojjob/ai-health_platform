                <div class="col-span-2 text-gray-600">Remembers your language preference</div>
                <div class="col-span-1 text-gray-600">1 year</div>
                <div class="col-span-1 text-gray-600">First-party</div>
              </div>
              <div class="px-4 py-3 grid grid-cols-5">
