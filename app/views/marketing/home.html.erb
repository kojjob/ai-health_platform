<%= content_for :head do %>
  <title>MedGemma - AI-Powered Healthcare</title>
  <meta name="description" content="Experience instant medical consultations powered by Google's MedGemma AI. Get accurate diagnoses, 24/7 virtual care, and personalized health insights—all from your home.">
<% end %>

<!-- Hero Section -->
<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Animated Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-20 left-10 w-72 h-72 bg-blue-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-teal-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
    <div class="absolute bottom-20 right-20 w-64 h-64 bg-indigo-300 rounded-full mix-blend-multiply filter blur-xl opacity-60 animate-blob animation-delay-3000"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div data-controller="fade-in">
        <div class="inline-flex items-center px-4 py-2 bg-blue-100 rounded-full mb-6">
          <span class="flex h-2 w-2 relative mr-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span class="text-sm font-medium text-blue-800">AI-Powered Healthcare is Live</span>
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-bold text-gray-900 mb-6">
          Your Health,
          <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent animate-pulse-slow">
            Reimagined
          </span>
          with AI
        </h1>
        
        <p class="text-xl leading-relaxed text-gray-700 mb-8 max-w-xl">
          Experience instant medical consultations powered by Google's MedGemma AI. 
          Get accurate diagnoses, <span class="font-semibold text-blue-700">24/7 virtual care</span>, and personalized health insights—all from your home.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <%= link_to new_user_registration_path, 
              class: "inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-full hover:from-blue-700 hover:to-purple-700 hover:shadow-lg hover:shadow-blue-500/30 transform hover:-translate-y-1 transition-all duration-300" do %>
            <div class="relative">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-30"></span>
              <i class="fas fa-stethoscope relative mr-2"></i>
            </div>
            Start Free Consultation
            <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
          <% end %>
          
          <button class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-gray-700 bg-white border-2 border-gray-200 rounded-full hover:border-blue-500 hover:text-blue-600 hover:shadow-lg transition-all duration-300"
                  data-controller="modal"
                  data-action="click->modal#open">
            <div class="relative">
              <span class="absolute -inset-1 rounded-full bg-blue-100 animate-pulse-slow opacity-70"></span>
              <i class="fas fa-play-circle relative mr-2 text-blue-600"></i>
            </div>
            Watch Demo
          </button>
        </div>

        <!-- Trust Indicators -->
        <div class="flex flex-wrap items-center space-x-4 space-y-2 sm:space-y-0 sm:space-x-6 bg-white/80 backdrop-blur-sm py-3 px-5 rounded-xl shadow-sm">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center mr-2">
              <i class="fas fa-shield-alt text-blue-600"></i>
            </div>
            <span class="font-medium">HIPAA Compliant</span>
          </div>
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center mr-2">
              <i class="fas fa-lock text-purple-600"></i>
            </div>
            <span class="font-medium">256-bit Encryption</span>
          </div>
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center mr-2">
              <i class="fas fa-check-circle text-green-600"></i>
            </div>
            <span class="font-medium">FDA Registered</span>
          </div>
        </div>
      </div>

      <!-- Right Visual -->
      <div class="relative" data-controller="parallax">
        <div class="relative z-10">
          <div class="relative">
            <%= image_tag "doctor-ai-hero.png", 
                class: "w-full h-auto rounded-2xl shadow-2xl transform transition-transform hover:scale-[1.02] duration-700",
                alt: "AI-Powered Medical Consultation" %>
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-blue-600/20 to-purple-600/10 pointer-events-none"></div>
          </div>
          
          <!-- Floating Elements -->
          <div class="absolute -top-6 -right-6 bg-white rounded-2xl shadow-xl p-4 animate-float">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                <i class="fas fa-check text-green-600 text-xl"></i>
              </div>
              <div>
                <p class="font-semibold">AI Diagnosis</p>
                <p class="text-sm text-gray-600">95% Accuracy</p>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-4 animate-float animation-delay-2000">
            <div class="flex items-center space-x-3">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                <i class="fas fa-clock text-blue-600 text-xl"></i>
              </div>
              <div>
                <p class="font-semibold">Instant Results</p>
                <p class="text-sm text-gray-600">Under 30 seconds</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Section -->
<section class="py-20 relative">
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-purple-50"></div>
  <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z\' fill=\'%236366F1\' fill-opacity=\'0.1\' fill-rule=\'evenodd\'/%3E%3C/svg%3E');"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900">Trusted by Thousands</h2>
      <p class="text-lg text-gray-600 mt-2">Real results from real patients</p>
    </div>
    
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center bg-white rounded-xl shadow-md px-6 py-8 transform hover:-translate-y-1 transition-all duration-300" data-controller="counter">
        <div class="text-4xl lg:text-5xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          <span data-counter-target="number" data-counter-end-value="50000">0</span>+
        </div>
        <p class="mt-3 text-gray-600 font-medium">Happy Patients</p>
        <div class="mt-2 flex justify-center">
          <div class="flex text-yellow-400">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
