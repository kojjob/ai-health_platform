                <option>501+ employees</option>
              </select>
            </div>
            <button type="submit" class="w-full px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-lg font-medium hover:from-blue-600 hover:to-purple-700 transition-colors">
              Request Demo
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section class="py-20 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <p class="text-xl text-gray-600">Everything you need to know about our pricing and services</p>
    </div>

    <div class="space-y-6" data-controller="faq-accordion">
      <% @pricing_faqs.each_with_index do |faq, index| %>
        <div class="bg-white rounded-xl shadow-sm overflow-hidden" data-controller="fade-in">
          <button 
            class="w-full text-left px-6 py-4 flex items-center justify-between focus:outline-none"
            data-action="click->faq-accordion#toggle"
            data-faq-accordion-target="question"
            data-index="<%= index %>"
          >
            <h3 class="text-lg font-semibold text-gray-900"><%= faq[:question] %></h3>
            <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
          </button>
          <div class="px-6 pb-4 hidden" data-faq-accordion-target="answer" data-index="<%= index %>">
            <p class="text-gray-600"><%= faq[:answer] %></p>
          </div>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-12 pt-6 border-t border-gray-200" data-controller="fade-in">
      <p class="text-gray-600 mb-4">Still have questions about our pricing?</p>
      <a href="/contact" class="inline-flex items-center px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors">
        <i class="fas fa-envelope mr-2"></i>
        Contact Our Sales Team
      </a>
    </div>
  </div>
</section>

