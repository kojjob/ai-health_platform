<%= content_for :title, "Features - MedGemma Health" %>

<!-- Hero Section -->
<section class="pt-32 pb-20 relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <div class="absolute top-1/4 left-0 w-96 h-96 rounded-full bg-gradient-to-br from-blue-50 to-indigo-50 opacity-70 blur-3xl transform rotate-6 animate-pulse-slow"></div>
    <div class="absolute top-1/3 right-0 w-96 h-96 rounded-full bg-gradient-to-br from-purple-50 to-violet-50 opacity-70 blur-3xl transform -rotate-12 animate-pulse-slow"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 rounded-full bg-gradient-to-br from-green-50 to-emerald-50 opacity-50 blur-3xl animate-pulse-slow"></div>
    
    <!-- Decorative elements -->
    <div class="absolute top-40 right-1/4 w-24 h-24 rounded-full border-4 border-blue-100 opacity-30"></div>
    <div class="absolute bottom-20 right-1/3 w-12 h-12 rounded-full border-2 border-purple-100 opacity-30"></div>
    <div class="absolute bottom-32 left-1/5 w-16 h-16 rounded-full border-2 border-green-100 opacity-30"></div>
    
    <!-- Lines -->
    <div class="absolute top-1/3 left-0 w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent opacity-30"></div>
    <div class="absolute top-2/3 left-0 w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent opacity-30"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-24" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-50 to-purple-50 rounded-full mb-6 shadow-sm">
        <span class="bg-blue-600/10 w-6 h-6 flex items-center justify-center rounded-full mr-2">
          <i class="fas fa-sparkles text-blue-600 text-xs"></i>
        </span>
        <span class="text-sm font-medium text-blue-800">Powerful Features</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        Experience the Future of
        <span class="relative">
          <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent inline-block mt-2">
            Healthcare Technology
          </span>
          <svg class="absolute bottom-0 left-0 w-full h-3 opacity-20" viewBox="0 0 200 9" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,4 C50,0 150,0 200,4 C150,8 50,8 0,4" fill="none" stroke="url(#gradient)" stroke-width="2"/>
            <defs>
              <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#3B82F6"/>
                <stop offset="100%" stop-color="#8B5CF6"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h1>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-10">
        Explore our comprehensive suite of features designed to revolutionize healthcare delivery and patient care.
      </p>
      
      <!-- Feature Cards -->
      <div class="grid md:grid-cols-4 gap-6 mt-20 max-w-5xl mx-auto">
        <% feature_icons = [
          { icon: "fa-brain", color: "blue", text: "AI Diagnostics", desc: "Advanced neural networks" },
          { icon: "fa-video", color: "green", text: "Virtual Care", desc: "Seamless remote healthcare" },
          { icon: "fa-heart-pulse", color: "rose", text: "Patient Health", desc: "Complete care management" },
          { icon: "fa-shield-check", color: "purple", text: "Data Security", desc: "HIPAA-compliant protection" }
        ] %>
        
        <% feature_icons.each do |item| %>
          <div class="relative group" data-controller="fade-in">
            <div class="absolute inset-0 bg-gradient-to-r from-<%= item[:color] %>-400 to-<%= item[:color] %>-600 rounded-xl blur-md opacity-20 group-hover:opacity-40 transition-all duration-300"></div>
            <div class="bg-white backdrop-blur-sm rounded-xl p-6 shadow-md border border-gray-100 relative h-full flex flex-col items-center text-center transform transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-xl group-hover:shadow-<%= item[:color] %>-500/20">
              <div class="w-16 h-16 flex items-center justify-center rounded-xl bg-gradient-to-br from-<%= item[:color] %>-500 to-<%= item[:color] %>-600 mb-5 shadow-lg shadow-<%= item[:color] %>-500/20 group-hover:scale-110 transition-all duration-300">
                <i class="fas <%= item[:icon] %> text-white text-xl"></i>
              </div>
              <span class="font-semibold text-gray-900 text-lg"><%= item[:text] %></span>
              <span class="text-sm text-gray-500 mt-1"><%= item[:desc] %></span>
              <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 translate-y-full opacity-0 group-hover:opacity-100 transition-all duration-300">
                <div class="bg-<%= item[:color] %>-500 text-white text-xs px-3 py-1 rounded-full whitespace-nowrap shadow-md">
                  Learn more
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Feature Categories -->
<% @feature_categories.each_with_index do |category, index| %>
  <% styles = feature_category_style(category[:name], index) %>
  <% illustration = feature_illustration(category[:name]) %>
  <% stats = feature_highlight_stats(category[:name]) %>
  <section class="py-24 <%= index.odd? ? 'bg-gray-50' : 'bg-white' %> relative overflow-hidden">
    <!-- Background decorations -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <div class="absolute -top-32 <%= index.odd? ? '-left-32' : '-right-32' %> w-72 h-72 rounded-full <%= styles[:pattern] %> <%= styles[:light_from] %> <%= styles[:light_to] %> opacity-60 blur-3xl transform rotate-6"></div>
      <div class="absolute -bottom-32 <%= index.odd? ? '-right-32' : '-left-32' %> w-72 h-72 rounded-full <%= styles[:pattern] %> <%= styles[:light_from] %> <%= styles[:light_to] %> opacity-60 blur-3xl transform -rotate-12"></div>
      
      <!-- Decorative polygon shape -->
      <div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none">
        <div 
          class="w-4/5 h-4/5 <%= styles[:pattern] %> opacity-20"
          style="clip-path: <%= illustration[:bg_accent][:pattern] %>; background: linear-gradient(135deg, <%= illustration[:bg_accent][:color1] %>, <%= illustration[:bg_accent][:color2] %>);"
        ></div>
      </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Category Info -->
        <div class="<%= index.odd? ? 'lg:order-2' : '' %> relative" data-controller="fade-in">
          <div class="absolute -top-10 -left-10 w-36 h-36 bg-gradient-to-br <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> opacity-10 rounded-full blur-xl"></div>
          
          <div class="relative">
            <div class="inline-flex items-center px-4 py-2 <%= styles[:pattern] %> <%= styles[:light_from] %> <%= styles[:light_to] %> rounded-full mb-6 shadow-sm">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> flex items-center justify-center shadow-sm">
                <i class="fas <%= styles[:icon] %> text-white text-sm"></i>
              </div>
              <span class="text-sm font-medium ml-2 <%= styles[:gradient_from].sub('from-', 'text-').sub('-500', '-800') %>">
                <%= category[:name].split(" ").first %>
              </span>
            </div>
            
            <h2 class="text-4xl font-bold text-gray-900 mb-6 relative">
              <%= category[:name] %>
              <span class="block mt-2 text-2xl bg-gradient-to-r <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> bg-clip-text text-transparent">
                <%= category[:description] %>
              </span>
              <div class="absolute -left-4 top-0 h-full w-1 bg-gradient-to-b <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> rounded-full hidden md:block"></div>
            </h2>
            
            <!-- Feature Stats -->
            <div class="flex items-center mb-12 bg-white rounded-xl p-4 shadow-sm border border-gray-100 w-max">
              <div class="mr-4">
                <div class="w-12 h-12 bg-gradient-to-br <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> rounded-lg flex items-center justify-center shadow-lg shadow-<%= styles[:color_class] %>-500/20">
                  <i class="fas <%= stats[:icon] %> text-white"></i>
                </div>
              </div>
              <div>
                <div class="text-2xl font-bold <%= styles[:gradient_from].sub('from-', 'text-').sub('-500', '-600') %>"><%= stats[:stat] %></div>
                <div class="text-sm text-gray-500"><%= stats[:text] %></div>
              </div>
            </div>
            
            <!-- Feature List -->
            <div class="space-y-6 mt-12">
              <% category[:features].each_with_index do |feature, feature_index| %>
                <% icon_styles = feature_icon_style(feature[:title]) %>
                <div class="group" data-controller="fade-in" data-fade-in-delay-value="<%= feature_index * 100 %>">
                  <div class="flex items-start space-x-4 p-5 rounded-xl transition-all duration-500 hover:bg-white hover:shadow-xl <%= icon_styles[:hover] %> border border-transparent hover:border-gray-100">
                    <div class="flex-shrink-0">
                      <div class="relative">
                        <!-- Gradient background with animation -->
                        <div class="absolute inset-0 rounded-xl <%= icon_styles[:gradient] %> opacity-0 group-hover:opacity-100 blur-md transition-opacity duration-500"></div>
                        
                        <!-- Icon container -->
                        <div class="w-14 h-14 flex items-center justify-center rounded-xl <%= icon_styles[:bg] %> relative z-10 group-hover:bg-white transition-colors duration-500 group-hover:scale-110 transform">
                          <i class="fas <%= icon_styles[:icon] %> <%= icon_styles[:color] %> text-xl group-hover:text-<%= styles[:color_class] %>-600 transition-colors duration-300"></i>
                        </div>
                      </div>
                    </div>
                    <div>
                      <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-<%= styles[:color_class] %>-600 transition-colors"><%= feature[:title] %></h3>
                      <p class="text-gray-600"><%= feature[:description] %></p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- Illustration -->
        <div class="<%= index.odd? ? 'lg:order-1' : '' %> relative" data-controller="fade-in">
          <div class="relative">
            <!-- Background accent -->
            <div class="absolute -top-10 <%= index.odd? ? '-left-10' : '-right-10' %> w-56 h-56 bg-gradient-to-br <%= styles[:light_from] %> <%= styles[:light_to] %> opacity-80 rounded-full blur-2xl transform rotate-12"></div>
            
            <!-- Main image container with animation -->
            <div class="relative <%= styles[:shape] %> bg-white p-3 shadow-xl hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 hover:shadow-<%= styles[:color_class] %>-500/20 group">
              <!-- Tilt effect with the angle from styles -->
              <div class="transform <%= styles[:angle] %> transition-transform duration-700 group-hover:rotate-0">
                <div class="aspect-w-4 aspect-h-3 rounded-xl overflow-hidden shadow-lg">
                  <img 
                    src="<%= illustration[:url] %>" 
                    alt="<%= illustration[:alt] %>" 
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end group-hover:from-black/60 transition-all duration-300">
                    <div class="p-6 w-full">
                      <span class="px-4 py-2 bg-white/90 backdrop-blur-sm text-sm font-medium text-gray-800 rounded-full inline-flex items-center shadow-sm">
                        <i class="fas <%= styles[:icon] %> mr-2 <%= styles[:gradient_from].sub('from-', 'text-').sub('-500', '-600') %>"></i>
                        <%= category[:name] %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Feature highlight -->
              <div class="absolute -bottom-5 right-8 transform translate-y-full">
                <div class="bg-gradient-to-r <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> text-white rounded-full px-4 py-2 shadow-lg shadow-<%= styles[:color_class] %>-500/30 inline-flex items-center">
                  <i class="fas fa-lightbulb mr-2"></i>
                  <span class="text-sm font-medium"><%= illustration[:highlight] %></span>
                </div>
              </div>
              
              <!-- Decorative elements -->
              <div class="absolute -top-2 -right-2 w-6 h-6 bg-gradient-to-br <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> rounded-full shadow-lg opacity-80"></div>
              <div class="absolute -bottom-2 -left-2 w-4 h-4 bg-gradient-to-br <%= styles[:gradient_from] %> <%= styles[:gradient_to] %> rounded-full shadow-lg opacity-80"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
<% end %>

<!-- CTA Section -->
<section class="py-28 relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-purple-50 to-white"></div>
    
    <!-- Background shapes -->
    <div class="absolute left-0 top-1/4 w-64 h-64 bg-blue-100 rounded-full mix-blend-multiply opacity-30 blur-3xl"></div>
    <div class="absolute right-0 top-1/3 w-64 h-64 bg-purple-100 rounded-full mix-blend-multiply opacity-30 blur-3xl"></div>
    
    <!-- Animated dots -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute left-1/4 top-1/4 w-2 h-2 bg-blue-500 rounded-full animate-ping" style="animation-delay: 0s; animation-duration: 3s;"></div>
      <div class="absolute left-3/4 top-1/2 w-2 h-2 bg-purple-500 rounded-full animate-ping" style="animation-delay: 0.5s; animation-duration: 3.5s;"></div>
      <div class="absolute left-1/3 top-2/3 w-2 h-2 bg-indigo-500 rounded-full animate-ping" style="animation-delay: 1s; animation-duration: 4s;"></div>
      <div class="absolute left-2/3 top-1/4 w-2 h-2 bg-green-500 rounded-full animate-ping" style="animation-delay: 1.5s; animation-duration: 4.5s;"></div>
    </div>
    
    <!-- Decorative lines -->
    <div class="absolute left-0 top-1/2 w-full h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent"></div>
    <div class="absolute left-0 top-1/4 w-full h-px bg-gradient-to-r from-transparent via-purple-200 to-transparent"></div>
    <div class="absolute left-0 top-3/4 w-full h-px bg-gradient-to-r from-transparent via-indigo-200 to-transparent"></div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100" data-controller="fade-in">
      <div class="grid md:grid-cols-5 items-stretch">
        <!-- Left side with image/pattern -->
        <div class="md:col-span-2 relative hidden md:block">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-purple-600">
            <!-- Abstract pattern overlay -->
            <div class="absolute inset-0 opacity-20">
              <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'20\' height=\'20\' viewBox=\'0 0 20 20\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.3\' fill-rule=\'evenodd\'%3E%3Ccircle cx=\'3\' cy=\'3\' r=\'3\'/%3E%3Ccircle cx=\'13\' cy=\'13\' r=\'3\'/%3E%3C/g%3E%3C/svg%3E'); background-size: 24px 24px;"></div>
            </div>
            
            <!-- Quote -->
            <div class="absolute inset-0 flex flex-col items-center justify-center p-6">
              <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center mb-6">
                <i class="fas fa-quote-left text-white/80 text-2xl"></i>
              </div>
              <p class="text-white/90 text-lg font-medium italic text-center">
                MedGemma has transformed our approach to healthcare delivery.
              </p>
              <div class="mt-6">
                <p class="text-white/80 font-medium">Dr. Sarah Johnson</p>
                <p class="text-white/60 text-sm">Chief Medical Officer</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right side with CTA content -->
        <div class="md:col-span-3 p-8 md:p-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Ready to Experience 
            <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent inline-block">
              Better Healthcare?
            </span>
          </h2>
          
          <p class="text-xl text-gray-600 mb-8">
            Join thousands of patients and healthcare providers who are already benefiting from our platform.
          </p>
          
          <div class="grid sm:grid-cols-2 gap-4">
            <%= link_to "Get Started", "#", class: "px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-medium hover:shadow-lg hover:shadow-blue-500/30 transform hover:-translate-y-0.5 transition-all text-center" %>
            <%= link_to "Schedule Demo", "#", class: "px-8 py-4 bg-white border-2 border-blue-600 text-blue-600 rounded-xl font-medium hover:bg-blue-50 transform hover:-translate-y-0.5 transition-all text-center" %>
          </div>
          
          <!-- Stats -->
          <div class="mt-12 grid grid-cols-3 gap-4 border-t border-gray-100 pt-8">
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900">10k+</div>
              <div class="text-sm text-gray-500">Patients</div>
            </div>
            <div class="text-center border-x border-gray-100">
              <div class="text-3xl font-bold text-gray-900">98%</div>
              <div class="text-sm text-gray-500">Satisfaction</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-gray-900">24/7</div>
              <div class="text-sm text-gray-500">Support</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
