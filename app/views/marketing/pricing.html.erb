          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-blue-200 mb-1">Organization Name</label>
              <input type="text" class="w-full px-4 py-2 bg-blue-700 border border-blue-600 rounded-lg text-white placeholder-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-blue-200 mb-1">Your Name</label>
              <input type="text" class="w-full px-4 py-2 bg-blue-700 border border-blue-600 rounded-lg text-white placeholder-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-blue-200 mb-1">Business Email</label>
              <input type="email" class="w-full px-4 py-2 bg-blue-700 border border-blue-600 rounded-lg text-white placeholder-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-blue-200 mb-1">Phone Number</label>
              <input type="tel" class="w-full px-4 py-2 bg-blue-700 border border-blue-600 rounded-lg text-white placeholder-blue-300 focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-blue-200 mb-1">Organization Size</label>
              <select class="w-full px-4 py-2 bg-blue-700 border border-blue-600 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
