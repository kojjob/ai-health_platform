<%= content_for :title, "About MedGemma Health - Revolutionizing Healthcare with AI" %>

<!-- Hero Section -->
<section class="pt-32 pb-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-blue-100 rounded-full mb-6">
        <i class="fas fa-hospital-user text-blue-600 mr-2"></i>
        <span class="text-sm font-medium text-blue-800">Transforming Healthcare</span>
      </div>
      
      <h1 class="text-5xl font-bold text-gray-900 mb-6">
        Our Vision for
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          Modern Healthcare
        </span>
      </h1>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        We're building a future where quality healthcare is accessible to everyone, powered by AI and delivered by trusted medical professionals.
      </p>
    </div>

    <!-- Mission Stats -->
    <div class="relative mb-20">
      <!-- Background decorations -->
      <div class="absolute top-10 left-10 w-64 h-64 bg-blue-50 rounded-full -z-10 blur-3xl opacity-70"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-purple-50 rounded-full -z-10 blur-3xl opacity-70"></div>
      
      <div class="grid md:grid-cols-3 gap-8" data-controller="fade-in">
        <% stats = [
          { number: "100K+", text: "Patients Helped", icon: "fa-users", color: "blue" },
          { number: "1,000+", text: "Verified Doctors", icon: "fa-user-md", color: "green" },
          { number: "30+", text: "Countries Served", icon: "fa-globe", color: "purple" }
        ] %>
        
        <% stats.each do |stat| %>
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-r from-<%= stat[:color] %>-500 to-<%= stat[:color] %>-600 rounded-2xl blur-md opacity-20 group-hover:opacity-30 transition-opacity"></div>
            <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 relative h-full flex flex-col items-center text-center transform transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-xl overflow-hidden">
              <!-- Light glow effect in background -->
              <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-<%= stat[:color] %>-100 rounded-full opacity-50"></div>
              
              <div class="w-16 h-16 bg-gradient-to-br from-<%= stat[:color] %>-500 to-<%= stat[:color] %>-600 rounded-full flex items-center justify-center mb-6 shadow-lg transform -rotate-3">
                <i class="fas <%= stat[:icon] %> text-white text-2xl"></i>
              </div>
              
              <h3 class="text-4xl font-bold text-gray-900 mb-3"><%= stat[:number] %></h3>
              <p class="text-<%= stat[:color] %>-600 font-medium"><%= stat[:text] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Our Story Section -->
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center relative">
      <div class="absolute top-0 left-0 w-32 h-32 bg-blue-50 rounded-full opacity-70 -z-10 blur-xl"></div>
      <div class="absolute bottom-0 right-0 w-64 h-64 bg-purple-50 rounded-full opacity-70 -z-10 blur-3xl"></div>
      
      <div data-controller="fade-in" class="relative z-10">
        <div class="inline-flex items-center px-4 py-2 bg-blue-100 rounded-full mb-6">
          <i class="fas fa-history text-blue-600 mr-2"></i>
          <span class="text-sm font-medium text-blue-800">Est. 2024</span>
        </div>
        
        <h2 class="text-4xl font-bold text-gray-900 mb-6">Our Story</h2>
        <p class="text-lg text-gray-600 mb-6">
          Founded in 2024, MedGemma Health emerged from a simple yet powerful idea: 
          what if we could combine the expertise of skilled medical professionals with 
          the analytical power of artificial intelligence?
        </p>
        <p class="text-lg text-gray-600 mb-8">
          Our team of healthcare professionals, AI specialists, and tech innovators 
          came together with a shared mission to make quality healthcare accessible 
          to everyone, everywhere.
        </p>
        
        <div class="bg-white rounded-xl shadow-md p-4 inline-flex items-center space-x-4 border border-gray-100">
          <div class="flex -space-x-4">
            <div class="w-12 h-12 rounded-full border-2 border-white overflow-hidden">
              <%= team_photo("Dr. Sarah Smith") %>
            </div>
            <div class="w-12 h-12 rounded-full border-2 border-white overflow-hidden">
              <%= team_photo("John Doe") %>
            </div>
            <div class="w-12 h-12 rounded-full border-2 border-white overflow-hidden">
              <%= team_photo("Dr. Lisa Chen") %>
            </div>
          </div>
          <p class="text-gray-700 font-medium">Led by experienced healthcare professionals</p>
        </div>
      </div>

      <div class="relative z-10" data-controller="fade-in">
        <div class="absolute -top-5 -right-5 w-24 h-24 bg-gradient-to-br from-blue-600 to-purple-600 rounded-full opacity-20"></div>
        <div class="absolute -bottom-5 -left-5 w-32 h-32 bg-gradient-to-br from-green-600 to-blue-600 rounded-full opacity-10"></div>
        
        <div class="relative bg-white rounded-2xl p-3 shadow-lg">
          <div class="aspect-w-16 aspect-h-9 rounded-lg overflow-hidden shadow-sm">
            <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" 
                 alt="Healthcare professionals discussing AI diagnostics" 
                 class="w-full h-full object-cover" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end">
              <div class="p-4 md:p-6">
                <div class="inline-flex items-center px-3 py-1.5 bg-white/90 backdrop-blur-sm rounded-full mb-2">
                  <i class="fas fa-play-circle text-blue-600 mr-2"></i>
                  <span class="text-xs font-medium text-gray-800">Watch our story</span>
                </div>
                <h3 class="text-white font-medium text-lg md:text-xl">How MedGemma is transforming healthcare</h3>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Values Section -->
<section class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Our Core Values</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        The principles that guide everything we do at MedGemma Health
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% values = [
        { name: "Patient Privacy First", 
          description: "We maintain the highest standards of data security and patient confidentiality, exceeding HIPAA compliance requirements." },
        { name: "Quality Care", 
          description: "We never compromise on the quality of care, combining AI precision with human expertise for optimal health outcomes." },
        { name: "Accessibility", 
          description: "Healthcare should be accessible to everyone. We're breaking down barriers of distance, cost, and convenience." },
        { name: "Innovation", 
          description: "We continuously push the boundaries of what's possible in healthcare through technological advancement." },
        { name: "Trust", 
          description: "Building and maintaining trust with our patients and healthcare providers is fundamental to everything we do." },
        { name: "Continuous Improvement", 
          description: "We're committed to constantly improving our services through feedback, research, and technological advancement." }
      ] %>
      
      <% values.each do |value| %>
        <% icon_classes = value_icon_class(value[:name]) %>
        <div class="relative group" data-controller="fade-in">
          <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 h-full transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
            <div class="absolute -top-3 -left-3 w-16 h-16 rounded-xl bg-gradient-to-br <%= icon_classes[:gradient] %> flex items-center justify-center transform -rotate-3 shadow-lg">
              <i class="fas <%= icon_classes[:icon] %> text-white text-xl"></i>
            </div>
            <div class="pt-8 pl-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4"><%= value[:name] %></h3>
              <p class="text-gray-600">
                <%= value[:description] %>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Team Section -->
<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <h2 class="text-4xl font-bold text-gray-900 mb-6">Leadership Team</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Meet the experienced professionals leading the future of healthcare
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% team_members = [
        { 
          name: "Dr. Sarah Smith", 
          role: "CEO & Co-founder", 
          bio: "Former Chief of Digital Health at Mayo Clinic with 15+ years in healthcare innovation.",
          social: { linkedin: "#", twitter: "#" }
        },
        { 
          name: "John Doe", 
          role: "CTO & Co-founder", 
          bio: "AI researcher and former Tech Lead at DeepMind Health.",
          social: { linkedin: "#", twitter: "#", github: "#" }
        },
        { 
          name: "Dr. Lisa Chen", 
          role: "Chief Medical Officer", 
          bio: "Board-certified physician with expertise in telemedicine and digital health.",
          social: { linkedin: "#", twitter: "#" }
        }
      ] %>
      
      <% team_members.each do |member| %>
        <div class="group" data-controller="fade-in">
          <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-1">
            <div class="h-56 relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black opacity-40 z-10"></div>
              <div class="w-full h-full">
                <%= team_photo(member[:name], member[:role]) %>
              </div>
            </div>
            
            <div class="p-6 relative">
              <div class="absolute -top-8 right-4 flex space-x-2 z-20">
                <% member[:social].each do |platform, link| %>
                  <a href="<%= link %>" class="w-8 h-8 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-blue-50 transition-colors">
                    <i class="fab fa-<%= platform %> text-gray-700"></i>
                  </a>
                <% end %>
              </div>
              
              <div class="text-center">
                <h3 class="text-xl font-bold text-gray-900"><%= member[:name] %></h3>
                <p class="text-blue-600 font-medium mb-3"><%= member[:role] %></p>
                <p class="text-gray-600">
                  <%= member[:bio] %>
                </p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-20 relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-purple-50 opacity-80"></div>
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-100 rounded-full opacity-50 blur-3xl"></div>
  <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-100 rounded-full opacity-50 blur-3xl"></div>
  
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10" data-controller="fade-in">
    <div class="bg-white rounded-3xl shadow-xl p-10 md:p-14 border border-gray-100">
      <div class="text-center mb-10">
        <div class="inline-flex items-center px-4 py-2 bg-purple-100 rounded-full mb-6">
          <i class="fas fa-hand-holding-heart text-purple-600 mr-2"></i>
          <span class="text-sm font-medium text-purple-800">Join Our Mission</span>
        </div>
        
        <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          Join Us in <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">Transforming Healthcare</span>
        </h2>
        
        <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
          Whether you're a healthcare provider or a patient, be part of the revolution 
          in medical care delivery.
        </p>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="#" class="group">
          <div class="px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-medium shadow-lg shadow-blue-500/20 flex items-center justify-center space-x-3 transform transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-500/30">
            <i class="fas fa-user-md text-xl"></i>
            <span>Join as a Doctor</span>
            <i class="fas fa-arrow-right opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"></i>
          </div>
        </a>
        
        <a href="#" class="group">
          <div class="px-8 py-4 bg-white border-2 border-blue-600 text-blue-600 rounded-xl font-medium shadow-lg shadow-blue-100/20 flex items-center justify-center space-x-3 transform transition-all duration-300 hover:-translate-y-1 hover:bg-blue-50 hover:shadow-xl hover:shadow-blue-100/30">
            <i class="fas fa-user-plus text-xl"></i>
            <span>Sign Up as a Patient</span>
            <i class="fas fa-arrow-right opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300"></i>
          </div>
        </a>
      </div>
      
      <div class="mt-10 pt-10 border-t border-gray-100 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-blue-600 mb-2"><i class="fas fa-shield-alt text-xl"></i></div>
          <h4 class="font-medium text-gray-800">HIPAA Compliant</h4>
        </div>
        
        <div>
          <div class="text-blue-600 mb-2"><i class="fas fa-lock text-xl"></i></div>
          <h4 class="font-medium text-gray-800">Secure Platform</h4>
        </div>
        
        <div>
          <div class="text-blue-600 mb-2"><i class="fas fa-headset text-xl"></i></div>
          <h4 class="font-medium text-gray-800">24/7 Support</h4>
        </div>
        
        <div>
          <div class="text-blue-600 mb-2"><i class="fas fa-mobile-alt text-xl"></i></div>
          <h4 class="font-medium text-gray-800">Mobile App</h4>
        </div>
      </div>
    </div>
  </div>
</section>
