<% content_for :title, "Community Hub | MedGemma Health" %>
<% content_for :meta_description, "Join 50,000+ healthcare professionals and patients in the MedGemma Health community. Connect, learn, and shape the future of AI-powered healthcare together." %>
<% content_for :canonical_url, community_url %>
<% content_for :open_graph do %>
  <meta property="og:title" content="MedGemma Health Community | Connect, Learn, Grow">
  <meta property="og:description" content="Join our thriving community of healthcare professionals, patients, and innovators. Share experiences, get support, and help shape the future of healthcare.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= community_url %>">
  <meta property="og:image" content="<%= asset_url('marketing/community-hero.png') %>">
<% end %>

<!-- Performance optimization: Preload critical resources -->
<% content_for :head do %>
  <link rel="preload" href="<%= asset_path('marketing/community-forums.png') %>" as="image">
  <link rel="preload" href="<%= asset_path('marketing/community-events.png') %>" as="image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <style>
    /* Critical CSS for above-the-fold content */
    .community-hero-bg {
      background: linear-gradient(135deg, #f8fafc 0%, #ffffff 50%, #eff6ff 100%);
    }
    .animate-float-community {
      animation: floatCommunity 6s ease-in-out infinite;
    }
    @keyframes floatCommunity {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(3deg); }
    }
    .stats-counter {
      animation: fadeInUp 0.8s ease-out forwards;
      opacity: 0;
    }
  </style>
<% end %>

<!-- Skip to main content link for accessibility -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-medgemma-600 focus:shadow-lg focus:rounded-md">
  Skip to main content
</a>

<!-- Enhanced Hero Section -->
