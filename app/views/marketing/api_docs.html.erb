<!-- API Newsletter -->
<section class="py-20 bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-controller="fade-in">
    <div class="mb-6">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full">
        <i class="fas fa-envelope-open-text text-indigo-600 text-2xl"></i>
      </div>
    </div>
    
    <h2 class="text-3xl font-bold text-gray-900 mb-4">Stay Updated</h2>
    <p class="text-lg text-gray-600 mb-8">
      Subscribe to our developer newsletter for API updates, new features, and best practices
    </p>
    
    <div class="flex flex-col sm:flex-row space-y-2 sm:space-y-0 sm:space-x-2 max-w-lg mx-auto">
