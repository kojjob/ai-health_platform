        <div class="hidden md:block relative">
          <img src="https://images.unsplash.com/photo-1581090700227-1e37b190418e?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8OHx8ZGV2ZWxvcGVyfGVufDB8fDB8fA%3D%3D&auto=format&fit=crop&w=800&q=80" 
               alt="Developer support team" 
               class="h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-l from-transparent to-blue-600/30"></div>
        </div>
      </div>
