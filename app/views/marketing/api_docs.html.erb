<%= content_for :title, "API Documentation - MedGemma Health" %>
<%= content_for :meta_description, "Comprehensive documentation for MedGemma Health's RESTful API, including authentication, endpoints, request and response formats." %>

<!-- Hero Section -->
<section class="pt-32 pb-20 bg-gradient-to-br from-slate-50 to-blue-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-blue-100 rounded-full mb-6">
        <i class="fas fa-code text-blue-600 mr-2"></i>
        <span class="text-sm font-medium text-blue-800">Developer Resources</span>
      </div>
      
      <h1 class="text-5xl font-bold text-gray-900 mb-6">
        MedGemma Health
        <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
          API Documentation
        </span>
      </h1>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
        Build healthcare solutions with our secure and powerful API designed for developers and integrators.
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-10">
        <a href="#quick-start" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-medium rounded-lg shadow-md hover:shadow-lg transition-all hover:-translate-y-1">
          <i class="fas fa-rocket mr-2"></i>
          Quick Start Guide
        </a>
        <a href="https://github.com/medgemma/api-examples" class="inline-flex items-center px-6 py-3 bg-white text-gray-800 border border-gray-300 font-medium rounded-lg shadow-sm hover:shadow hover:bg-gray-50 transition-all">
          <i class="fab fa-github mr-2"></i>
          Sample Code
        </a>
      </div>
      
      <!-- API Versions -->
      <div class="flex justify-center space-x-4">
        <% @api_versions.each do |version| %>
          <div class="bg-white px-4 py-2 rounded-lg border <%= version[:status] == 'current' ? 'border-blue-300 bg-blue-50' : 'border-gray-300' %> flex items-center space-x-2">
            <div class="text-lg font-semibold"><%= version[:version].upcase %></div>
            <% if version[:status] == 'current' %>
              <span class="text-xs bg-blue-600 text-white px-2 py-0.5 rounded-full uppercase">Current</span>
            <% else %>
              <span class="text-xs bg-gray-500 text-white px-2 py-0.5 rounded-full uppercase">Legacy</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- API Overview -->
<section id="quick-start" class="py-20 bg-white" data-controller="api-docs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-3 gap-12">
      <!-- Mobile Navigation Toggle -->
      <div class="block lg:hidden mb-6">
        <button id="toggleApiNav" class="w-full flex items-center justify-between bg-blue-50 p-4 rounded-lg">
          <div class="flex items-center">
            <i class="fas fa-bars text-blue-600 mr-2"></i>
            <span class="font-medium text-gray-800">API Documentation Menu</span>
          </div>
          <i class="fas fa-chevron-down text-gray-500"></i>
        </button>
      </div>
      
      <!-- Sidebar - API Navigation -->
      <div class="lg:col-span-1 hidden lg:block" id="apiNavContent">
        <div class="lg:sticky lg:top-24 bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden" data-controller="fade-in">
          <div class="bg-gray-50 p-4 border-b border-gray-200">
            <h3 class="font-bold text-gray-900">API Documentation</h3>
          </div>
          
          <nav class="p-2">
            <ul class="space-y-1">
              <li>
                <a href="#overview" class="flex items-center px-3 py-2 text-blue-600 bg-blue-50 rounded-lg font-medium">
                  <i class="fas fa-home w-5 h-5 mr-2"></i>
                  Overview
                </a>
              </li>
              <li>
                <a href="#authentication" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-lock w-5 h-5 mr-2 text-gray-400"></i>
                  Authentication
                </a>
              </li>
              <li>
                <a href="#endpoints" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-link w-5 h-5 mr-2 text-gray-400"></i>
                  API Endpoints
                </a>
              </li>
              <li>
                <a href="#errors" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-exclamation-triangle w-5 h-5 mr-2 text-gray-400"></i>
                  Error Handling
                </a>
              </li>
              <li>
                <a href="#rate-limits" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-tachometer-alt w-5 h-5 mr-2 text-gray-400"></i>
                  Rate Limits
                </a>
              </li>
              <li>
                <a href="#webhooks" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-exchange-alt w-5 h-5 mr-2 text-gray-400"></i>
                  Webhooks
                </a>
              </li>
              <li>
                <a href="#sdks" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                  <i class="fas fa-cube w-5 h-5 mr-2 text-gray-400"></i>
                  SDKs & Libraries
                </a>
              </li>
            </ul>
            
            <div class="mt-6 pt-6 border-t border-gray-200">
              <h4 class="px-3 mb-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Resources</h4>
              <ul class="space-y-1">
                <li>
                  <a href="#" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                    <i class="fas fa-book w-5 h-5 mr-2 text-gray-400"></i>
                    API Reference
                  </a>
                </li>
                <li>
                  <a href="#" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                    <i class="fas fa-file-code w-5 h-5 mr-2 text-gray-400"></i>
                    Swagger Spec
                  </a>
                </li>
                <li>
                  <a href="#" class="flex items-center px-3 py-2 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                    <i class="fas fa-question-circle w-5 h-5 mr-2 text-gray-400"></i>
                    API Support
                  </a>
                </li>
              </ul>
            </div>
          </nav>
        </div>
      </div>
      
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-12" data-controller="fade-in">
        <!-- Overview -->
        <div id="overview" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-gray-50 p-6 border-b border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900">API Overview</h2>
          </div>
          
          <div class="p-6">
            <p class="text-gray-600 mb-6">
              The MedGemma Health API provides secure, RESTful endpoints for integrating healthcare services into your applications. Our API follows modern standards and best practices to ensure reliability and security.
            </p>
            
            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Base URL</h3>
              <div class="bg-gray-900 text-white p-3 rounded-md font-mono text-sm overflow-x-auto">
                https://api.medgemma.com/v2
              </div>
            </div>
            
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Key Features</h3>
            <ul class="space-y-3">
              <li class="flex">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                    <i class="fas fa-shield-alt text-blue-600"></i>
                  </div>
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-gray-900">HIPAA Compliance</h4>
                  <p class="text-gray-600">All API endpoints adhere to strict healthcare data regulations</p>
                </div>
              </li>
              <li class="flex">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                    <i class="fas fa-lock text-blue-600"></i>
                  </div>
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-gray-900">Secure OAuth 2.0</h4>
                  <p class="text-gray-600">Industry-standard authentication and authorization</p>
                </div>
              </li>
              <li class="flex">
                <div class="flex-shrink-0">
                  <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                    <i class="fas fa-tachometer-alt text-blue-600"></i>
                  </div>
                </div>
                <div class="ml-4">
                  <h4 class="font-medium text-gray-900">High Performance</h4>
                  <p class="text-gray-600">99.9% uptime with globally distributed endpoints</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        
        <!-- Authentication -->
        <div id="authentication" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-gray-50 p-6 border-b border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900">Authentication</h2>
          </div>
          
          <div class="p-6">
            <p class="text-gray-600 mb-6">
              MedGemma Health API uses OAuth 2.0 for secure authentication. To make authenticated requests, you'll need to obtain an access token.
            </p>
            
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Obtaining API Keys</h3>
              <ol class="list-decimal ml-6 space-y-2 text-gray-600">
                <li>Create a developer account in the <a href="#" class="text-blue-600 hover:underline">MedGemma Developer Portal</a></li>
                <li>Register your application to receive client credentials</li>
                <li>Use your client ID and secret to request access tokens</li>
              </ol>
            </div>
            
            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">Example Authentication Request</h3>
              <div class="bg-gray-900 text-white p-3 rounded-md font-mono text-sm overflow-x-auto">
                <div class="text-gray-400">// Request an access token</div>
                POST https://api.medgemma.com/oauth/token<br>
                Content-Type: application/json<br>
                <br>
                {<br>
                &nbsp;&nbsp;"client_id": "your_client_id",<br>
                &nbsp;&nbsp;"client_secret": "your_client_secret",<br>
                &nbsp;&nbsp;"grant_type": "client_credentials"<br>
                }
              </div>
            </div>
            
            <div class="bg-blue-50 rounded-lg p-4 border border-blue-100">
              <div class="flex items-start">
                <div class="flex-shrink-0 pt-0.5">
                  <i class="fas fa-info-circle text-blue-600"></i>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-blue-800">Security Note</h3>
                  <div class="text-sm text-blue-700">
                    Never expose your client secret in client-side code. Always make token requests from your server.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- API Endpoints -->
        <div id="endpoints" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="bg-gray-50 p-6 border-b border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900">API Endpoints</h2>
          </div>
          
          <div class="p-6">
            <p class="text-gray-600 mb-6">
              MedGemma Health API provides a comprehensive set of endpoints to interact with our healthcare platform. Below are the main endpoint categories:
            </p>
            
            <div class="space-y-6">
              <% @api_endpoints.each do |endpoint| %>
                <div class="border border-gray-200 rounded-lg overflow-hidden">
                  <div class="bg-gray-50 px-4 py-3 flex justify-between items-center">
                    <h3 class="font-medium text-gray-900">
                      <%= endpoint[:name] %>
                    </h3>
                    <a href="<%= endpoint[:path] %>" class="text-sm text-blue-600 hover:text-blue-800">
                      View Documentation
                    </a>
                  </div>
                  <div class="p-4">
                    <p class="text-gray-600 text-sm mb-3"><%= endpoint[:description] %></p>
                    <div class="grid grid-cols-2 gap-2">
                      <div class="flex items-center">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-green-100 text-green-800">
                          GET
                        </span>
                        <span class="ml-2 text-xs font-mono text-gray-600">/v2/<%= endpoint[:name].downcase %></span>
                      </div>
                      <div class="flex items-center">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-100 text-blue-800">
                          POST
                        </span>
                        <span class="ml-2 text-xs font-mono text-gray-600">/v2/<%= endpoint[:name].downcase %></span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            
            <div class="mt-6 text-center">
              <a href="#" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                View Complete API Reference
                <i class="fas fa-external-link-alt ml-2"></i>
              </a>
            </div>
          </div>
        </div>
        
        <!-- Additional API Information -->
        <div class="space-y-8">
          <!-- Error Handling -->
          <div id="errors" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 p-4 border-b border-gray-200">
              <h2 class="text-xl font-bold text-gray-900">Error Handling</h2>
            </div>
            
            <div class="p-4">
              <p class="text-gray-600 mb-4">
                The API uses conventional HTTP response codes to indicate the success or failure of API requests.
              </p>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="bg-green-50 p-3 rounded-md border border-green-100">
                  <h3 class="text-green-800 font-medium mb-1">2xx - Success</h3>
                  <p class="text-green-700 text-sm">Request processed successfully</p>
                </div>
                
                <div class="bg-yellow-50 p-3 rounded-md border border-yellow-100">
                  <h3 class="text-yellow-800 font-medium mb-1">4xx - Client Error</h3>
                  <p class="text-yellow-700 text-sm">Invalid request or authentication failure</p>
                </div>
                
                <div class="bg-red-50 p-3 rounded-md border border-red-100 sm:col-span-2">
                  <h3 class="text-red-800 font-medium mb-1">5xx - Server Error</h3>
                  <p class="text-red-700 text-sm">Request could not be processed due to a server error</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Rate Limits -->
          <div id="rate-limits" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 p-4 border-b border-gray-200">
              <h2 class="text-xl font-bold text-gray-900">Rate Limits</h2>
            </div>
            
            <div class="p-4">
              <p class="text-gray-600 mb-4">
                To ensure service stability, the API enforces rate limits on requests. Limits vary by endpoint and plan tier.
              </p>
              
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plan</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Requests/Min</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Daily Limit</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Developer</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">60</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">10,000</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Business</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">300</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">100,000</td>
                    </tr>
                    <tr>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Enterprise</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">1000+</td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Custom</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SDK Section -->
<section id="sdks" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-indigo-100 rounded-full mb-6">
        <i class="fas fa-cube text-indigo-600 mr-2"></i>
        <span class="text-sm font-medium text-indigo-800">Client Libraries</span>
      </div>
      
      <h2 class="text-3xl font-bold text-gray-900 mb-4">SDK & Integration Libraries</h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        Accelerate your integration with our officially supported client libraries for popular programming languages
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-controller="fade-in">
      <% sdks = [
        { name: "JavaScript/TypeScript", icon: "js", color: "yellow" },
        { name: "Python", icon: "python", color: "blue" },
        { name: "Ruby", icon: "gem", color: "red" },
        { name: "Java", icon: "java", color: "orange" },
        { name: "C#/.NET", icon: "microsoft", color: "purple" },
        { name: "Go", icon: "code", color: "teal" }
      ] %>
      
      <% sdks.each do |sdk| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden transition-all hover:shadow-md hover:-translate-y-1 transform duration-300">
          <div class="p-6 flex items-start">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 rounded-full bg-<%= sdk[:color] %>-100 flex items-center justify-center">
                <i class="fab fa-<%= sdk[:icon] %> text-<%= sdk[:color] %>-600 text-xl"></i>
              </div>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-semibold text-gray-900 mb-2"><%= sdk[:name] %> SDK</h3>
              <div class="flex space-x-3">
                <a href="#" class="text-sm text-blue-600 hover:underline">Documentation</a>
                <a href="#" class="text-sm text-blue-600 hover:underline">GitHub</a>
                <a href="#" class="text-sm text-blue-600 hover:underline">Examples</a>
              </div>
            </div>
          </div>
          
          <div class="px-6 py-2 bg-gray-50 text-sm text-gray-600">
            <span class="inline-flex items-center">
              <i class="far fa-file-alt mr-1 text-gray-500"></i>
              MIT License
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- API Support -->
<section class="py-20 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-3xl shadow-xl overflow-hidden" data-controller="fade-in">
      <div class="md:grid md:grid-cols-2 md:gap-0">
        <div class="px-6 py-10 md:p-12 text-white">
          <h2 class="text-3xl font-bold mb-4">Need Help with Integration?</h2>
          <p class="text-blue-50 mb-6">
            Our developer support team is ready to assist with your API integration questions and challenges.
          </p>
          
          <div class="space-y-4">
            <a href="#" class="flex items-center group">
              <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mr-3 group-hover:bg-white/30 transition-colors">
