<%= content_for :title, "About MedGemma Health - Revolutionizing Healthcare with AI" %>
<%= content_for :meta_description, "Learn about MedGemma Health's mission to revolutionize healthcare through AI-powered diagnostics, virtual consultations, and accessible medical care for everyone." %>
<%= content_for :canonical_url, about_url %>
<%= content_for :open_graph do %>
  <meta property="og:title" content="About MedGemma Health | AI-Powered Healthcare Innovation">
  <meta property="og:description" content="Meet the team revolutionizing healthcare with AI. Learn our story, values, and mission to make quality healthcare accessible to everyone through innovative technology.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= about_url %>">
  <meta property="og:image" content="<%= asset_url('marketing/about-hero.png') %>">
<% end %>

<!-- Performance optimization: Preload critical resources -->
<%= content_for :head do %>
  <link rel="preload" href="<%= asset_path('marketing/about-story.png') %>" as="image">
  <link rel="preload" href="<%= asset_path('marketing/team-leadership.png') %>" as="image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <style>
    /* Critical CSS for above-the-fold content */
    .about-hero-bg {
      background: linear-gradient(135deg, #f8fafc 0%, #ffffff 50%, #eff6ff 100%);
    }
    .animate-float-about {
      animation: floatAbout 7s ease-in-out infinite;
    }
    @keyframes floatAbout {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(2deg); }
    }
    .values-card-hover {
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .values-card-hover:hover {
      transform: translateY(-5px) scale(1.02);
    }
    .team-card-hover {
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .team-card-hover:hover {
      transform: translateY(-8px);
    }
  </style>
<% end %>

<!-- Skip to content link for accessibility -->
<a href="#main-content" 
   class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-blue-600 focus:shadow-lg focus:rounded-md">
  Skip to main content
</a>

<!-- Enhanced Hero Section -->
<section id="main-content" class="pt-32 pb-20 about-hero-bg relative overflow-hidden" data-controller="analytics fade-in" data-analytics-page-value="about" data-analytics-section-value="hero">
  <!-- Enhanced background decorations -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <!-- Large gradient orbs -->
    <div class="absolute top-0 left-0 w-96 h-96 bg-gradient-to-br from-blue-100/30 to-purple-100/20 rounded-full -translate-x-1/2 -translate-y-1/4 will-change-transform"></div>
    <div class="absolute top-1/4 right-0 w-80 h-80 bg-gradient-to-bl from-indigo-100/40 to-teal-100/30 rounded-full translate-x-1/3 will-change-transform"></div>
    <div class="absolute bottom-0 left-1/3 w-72 h-72 bg-gradient-to-t from-purple-100/30 to-pink-100/20 rounded-full will-change-transform"></div>
    
    <!-- Floating elements -->
    <div class="absolute top-1/3 left-1/4 w-24 h-24 bg-gradient-to-br from-emerald-100/20 to-teal-100/30 rounded-full animate-float-about"></div>
    <div class="absolute top-1/2 right-1/4 w-16 h-16 bg-gradient-to-br from-blue-100/30 to-indigo-100/20 rounded-full animate-float-about" style="animation-delay: -3s;"></div>
    <div class="absolute bottom-1/3 left-1/5 w-20 h-20 bg-gradient-to-br from-purple-100/25 to-pink-100/15 rounded-full animate-float-about" style="animation-delay: -5s;"></div>
    
    <!-- Geometric shapes -->
    <div class="absolute top-40 right-1/4 w-24 h-24 border-4 border-blue-100/50 rounded-2xl rotate-12 opacity-60"></div>
    <div class="absolute bottom-32 right-1/3 w-12 h-12 border-2 border-purple-100/50 rounded-full opacity-50"></div>
    <div class="absolute top-2/3 left-1/5 w-8 h-8 bg-blue-200/30 rounded-full"></div>
    <div class="absolute top-1/4 left-2/3 w-6 h-6 bg-purple-200/40 rotate-45"></div>
    
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    
    <!-- Subtle lines -->
    <div class="absolute top-1/3 left-0 w-full h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
    <div class="absolute top-2/3 left-0 w-full h-px bg-gradient-to-r from-transparent via-gray-200/40 to-transparent"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-50 to-purple-50 rounded-full mb-6 shadow-sm">
        <span class="bg-blue-600/10 w-6 h-6 flex items-center justify-center rounded-full mr-2">
          <i class="fas fa-hospital-user text-blue-600 text-xs"></i>
        </span>
        <span class="text-sm font-medium text-blue-800">Transforming Healthcare</span>
      </div>
      
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6 relative">
        Our Vision for
        <span class="relative">
          <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent inline-block">
            Modern Healthcare
          </span>
          <svg class="absolute bottom-0 left-0 w-full h-2 opacity-30" viewBox="0 0 200 4" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,2 C50,0 150,4 200,2" fill="none" stroke="url(#gradient-about)" stroke-width="2"/>
            <defs>
              <linearGradient id="gradient-about" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#3B82F6"/>
                <stop offset="100%" stop-color="#8B5CF6"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h1>
      
      <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
        We're building a future where quality healthcare is accessible to everyone, powered by AI and delivered by trusted medical professionals.
      </p>
    </div>

    <!-- Enhanced Mission Stats -->
    <div class="relative mb-20">
      <!-- Enhanced background decorations -->
      <div class="absolute top-10 left-10 w-64 h-64 bg-gradient-to-br from-blue-50/60 to-blue-100/40 rounded-full -z-10 blur-3xl opacity-70"></div>
      <div class="absolute bottom-10 right-10 w-64 h-64 bg-gradient-to-bl from-purple-50/60 to-purple-100/40 rounded-full -z-10 blur-3xl opacity-70"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-gradient-to-r from-teal-50/40 to-emerald-50/30 rounded-full -z-10 blur-2xl opacity-50"></div>
      
      <div class="grid md:grid-cols-3 gap-8" data-controller="fade-in">
        <% stats = [
          { number: "100K+", text: "Patients Helped", icon: "fa-users", color: "blue", accent: "indigo" },
          { number: "1,000+", text: "Verified Doctors", icon: "fa-user-md", color: "emerald", accent: "teal" },
          { number: "30+", text: "Countries Served", icon: "fa-globe", color: "purple", accent: "pink" }
        ] %>
        
        <% stats.each_with_index do |stat, index| %>
          <div class="relative group" style="animation-delay: <%= index * 0.2 %>s;">
            <!-- Enhanced glow effect -->
            <div class="absolute inset-0 bg-gradient-to-r from-<%= stat[:color] %>-500 to-<%= stat[:accent] %>-600 rounded-2xl blur-md opacity-20 group-hover:opacity-30 transition-all duration-500"></div>
            
            <!-- Main card -->
            <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-100 relative h-full flex flex-col items-center text-center transform transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-2xl overflow-hidden">
              <!-- Enhanced light glow effects -->
              <div class="absolute -top-4 -right-4 w-24 h-24 bg-gradient-to-br from-<%= stat[:color] %>-100/60 to-<%= stat[:accent] %>-100/40 rounded-full opacity-50"></div>
              <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-gradient-to-tr from-<%= stat[:color] %>-50/30 to-<%= stat[:accent] %>-50/20 rounded-full opacity-40"></div>
              
              <!-- Icon with enhanced styling -->
              <div class="relative w-16 h-16 bg-gradient-to-br from-<%= stat[:color] %>-500 to-<%= stat[:accent] %>-600 rounded-full flex items-center justify-center mb-6 shadow-lg transform group-hover:scale-110 transition-all duration-300" style="transform: rotate(-3deg);">
                <i class="fas <%= stat[:icon] %> text-white text-2xl"></i>
                <div class="absolute inset-0 bg-white/20 rounded-full blur-sm"></div>
              </div>
              
              <h3 class="text-4xl font-bold text-gray-900 mb-3 relative z-10"><%= stat[:number] %></h3>
              <p class="text-<%= stat[:color] %>-600 font-medium relative z-10"><%= stat[:text] %></p>
              
              <!-- Subtle sparkle effect -->
              <div class="absolute top-4 right-4 w-2 h-2 bg-<%= stat[:color] %>-400 rounded-full opacity-60 group-hover:opacity-100 transition-opacity"></div>
              <div class="absolute bottom-6 left-6 w-1.5 h-1.5 bg-<%= stat[:accent] %>-400 rounded-full opacity-40 group-hover:opacity-80 transition-opacity"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Enhanced Our Story Section -->
