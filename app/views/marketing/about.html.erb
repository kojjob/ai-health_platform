    <!-- Section header -->
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-white/80 backdrop-blur-sm rounded-full mb-6 shadow-sm">
        <i class="fas fa-book-open text-purple-600 mr-2"></i>
        <span class="text-sm font-medium text-purple-800">Learning Resources</span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-6">
        Helpful Resources & 
        <span class="relative">
          <span class="bg-gradient-to-r from-purple-600 to-blue-600 bg-clip-text text-transparent">
            Guides
          </span>
          <svg class="absolute bottom-0 left-0 w-full h-2 opacity-30" viewBox="0 0 200 4" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,2 C50,0 150,4 200,2" fill="none" stroke="url(#gradient-resources)" stroke-width="2"/>
            <defs>
              <linearGradient id="gradient-resources" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#8B5CF6"/>
                <stop offset="100%" stop-color="#3B82F6"/>
              </linearGradient>
            </defs>
          </svg>
        </span>
      </h2>
      <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
        Explore our comprehensive collection of guides, documentation, and resources to help you succeed with MedGemma Health.
      </p>
    </div>

    <!-- Resources grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% resources = [
        {
          title: "Getting Started Guide",
          description: "Step-by-step instructions to set up your MedGemma Health account and configure your first workflows.",
          icon: "fas fa-play-circle",
          type: "Guide",
          color: "blue",
          readTime: "5 min read"
        },
        {
          title: "API Documentation",
          description: "Complete reference for integrating MedGemma Health with your existing healthcare systems and applications.",
          icon: "fas fa-code",
          type: "Documentation",
          color: "green",
          readTime: "Technical"
        },
        {
          title: "Video Tutorials",
          description: "Watch our comprehensive video series covering all features of the MedGemma Health platform.",
          icon: "fas fa-video",
          type: "Videos",
          color: "purple",
          readTime: "Multiple"
        },
        {
          title: "Security Whitepaper",
          description: "Learn about our security measures, compliance standards, and data protection protocols.",
          icon: "fas fa-shield-alt",
          type: "Whitepaper",
          color: "red",
          readTime: "15 min read"
        },
        {
          title: "Best Practices",
          description: "Proven strategies and tips from healthcare professionals using MedGemma Health successfully.",
          icon: "fas fa-lightbulb",
          type: "Guide",
          color: "yellow",
          readTime: "8 min read"
        },
        {
          title: "System Status",
          description: "Real-time status updates and maintenance schedules for all MedGemma Health services.",
          icon: "fas fa-heartbeat",
          type: "Status",
          color: "indigo",
          readTime: "Live"
        }
      ] %>

      <% resources.each_with_index do |resource, index| %>
        <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 group cursor-pointer"
             data-controller="fade-in"
             style="animation-delay: <%= index * 0.1 %>s;">
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-<%= resource[:color] %>-100 rounded-xl flex items-center justify-center group-hover:bg-<%= resource[:color] %>-200 transition-colors">
              <i class="<%= resource[:icon] %> text-<%= resource[:color] %>-600 text-lg"></i>
            </div>
            <div class="text-xs bg-<%= resource[:color] %>-100 text-<%= resource[:color] %>-800 px-2 py-1 rounded-full">
              <%= resource[:type] %>
            </div>
          </div>
          
          <!-- Content -->
          <h3 class="font-bold text-gray-900 mb-2 group-hover:text-<%= resource[:color] %>-600 transition-colors">
            <%= resource[:title] %>
          </h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            <%= resource[:description] %>
          </p>
          
          <!-- Footer -->
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">
              <i class="fas fa-clock mr-1"></i>
              <%= resource[:readTime] %>
            </span>
            <div class="flex items-center text-<%= resource[:color] %>-600 text-sm font-medium group-hover:translate-x-1 transition-transform">
              Access <i class="fas fa-arrow-right ml-1 text-xs"></i>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-controller="fade-in">
      <a href="/help-center" class="inline-flex items-center px-8 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl">
        Browse All Resources
        <i class="fas fa-external-link-alt ml-2"></i>
      </a>
    </div>
  </div>
</section>

<!-- Newsletter Signup Section -->
<section class="py-20 bg-gradient-to-r from-blue-600 to-purple-700 relative overflow-hidden">
  <!-- Enhanced background decorations -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-300/10 rounded-full translate-x-1/2 translate-y-1/2 blur-3xl"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <div data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm rounded-full mb-6">
        <i class="fas fa-envelope text-white mr-2"></i>
        <span class="text-sm font-medium text-white">Stay Updated</span>
      </div>
      
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
        Subscribe to Our Healthcare Insights
      </h2>
      
      <p class="text-lg text-blue-100 mb-8 max-w-2xl mx-auto">
        Get the latest updates on healthcare technology, AI innovations, and industry best practices delivered to your inbox.
      </p>

      <!-- Newsletter form -->
      <div class="max-w-lg mx-auto" data-controller="fade-in">
        <%= form_with url: newsletter_subscription_path, 
            class: "flex flex-col sm:flex-row gap-4",
            data: { 
              controller: "newsletter-form",
              newsletter_form_target: "form",
              action: "submit->newsletter-form#submit"
            } do |form| %>
          <div class="flex-1">
            <%= form.email_field :email, 
                placeholder: "Enter your email address",
                class: "w-full px-4 py-3 rounded-lg border-2 border-white/20 bg-white/10 backdrop-blur-sm text-white placeholder-white/70 focus:border-white focus:bg-white/20 focus:outline-none transition-all duration-300",
                data: { newsletter_form_target: "email" },
                "aria-label": "Email address for newsletter" %>
          </div>
          <%= form.submit "Subscribe", 
              class: "px-8 py-3 bg-white text-blue-600 rounded-lg font-semibold hover:bg-blue-50 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 whitespace-nowrap",
              data: { newsletter_form_target: "submit" } %>
        <% end %>
        
        <p class="text-white/80 text-sm mt-4">
          No spam, unsubscribe at any time. Read our 
          <a href="/privacy" class="underline hover:no-underline">Privacy Policy</a>.
        </p>
      </div>

      <!-- Benefits -->
      <div class="grid md:grid-cols-3 gap-8 mt-12">
        <% benefits = [
          { icon: "fas fa-brain", title: "AI Insights", description: "Latest in AI healthcare technology" },
          { icon: "fas fa-users", title: "Industry Updates", description: "Healthcare industry news and trends" },
          { icon: "fas fa-lightbulb", title: "Best Practices", description: "Tips from healthcare professionals" }
        ] %>

        <% benefits.each do |benefit| %>
          <div class="text-center">
            <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mx-auto mb-4">
              <i class="<%= benefit[:icon] %> text-white text-lg"></i>
            </div>
            <h3 class="font-semibold text-white mb-2"><%= benefit[:title] %></h3>
            <p class="text-blue-100 text-sm"><%= benefit[:description] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
