        </div>
        <p class="mt-3 text-gray-600 font-medium">Diagnosis Accuracy</p>
        <div class="w-16 h-1 bg-gradient-to-r from-teal-400 to-green-400 rounded-full mx-auto mt-3"></div>
      </div>
      
      <div class="text-center bg-white rounded-xl shadow-md px-6 py-8 transform hover:-translate-y-1 transition-all duration-300" data-controller="counter">
        <div class="text-4xl lg:text-5xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">
          <span data-counter-target="number" data-counter-end-value="24">0</span>/7
        </div>
        <p class="mt-3 text-gray-600 font-medium">Available Support</p>
        <div class="flex justify-center mt-3 space-x-1">
          <div class="w-2 h-2 rounded-full bg-indigo-400"></div>
          <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
          <div class="w-2 h-2 rounded-full bg-indigo-600"></div>
          <div class="w-2 h-2 rounded-full bg-purple-500"></div>
          <div class="w-2 h-2 rounded-full bg-purple-600"></div>
        </div>
      </div>
      
      <div class="text-center bg-white rounded-xl shadow-md px-6 py-8 transform hover:-translate-y-1 transition-all duration-300" data-controller="counter">
        <div class="text-4xl lg:text-5xl font-bold bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent">
          <span data-counter-target="number" data-counter-end-value="30">0</span>s
        </div>
        <p class="mt-3 text-gray-600 font-medium">Average Response</p>
        <div class="flex justify-center mt-2">
          <i class="fas fa-bolt text-amber-500 text-lg"></i>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How It Works Section -->
<section class="py-20 relative bg-gray-50">
  <!-- Simplified Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-blue-50 to-indigo-50 opacity-50"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Cleaner Section Heading -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-2 bg-blue-100 text-blue-700 rounded-full text-sm font-medium mb-4">
        <i class="fas fa-route mr-2"></i>Simple 3-Step Process
      </span>
      
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
        How MedGemma
        <span class="text-blue-600">Works for You</span>
      </h2>
      
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Experience healthcare reimagined through our seamless, AI-powered journey to better health
      </p>
    </div>

    <!-- Simplified Process Timeline -->
    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
      
      <!-- Step 1: Symptom Description -->
      <div class="bg-white rounded-xl shadow-lg p-8 text-center lg:text-left relative">
        <!-- Step Number -->
        <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-500 text-white rounded-full text-2xl font-bold mb-6 mx-auto lg:mx-0">
          1
        </div>
        
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Describe Symptoms</h3>
        
        <!-- Image -->
        <div class="mb-6">
          <%= image_tag "marketing/symptoms.jpg", class: "w-full h-48 object-cover rounded-lg", alt: "MedGemma Symptom Description" %>
        </div>
        
        <p class="text-gray-600 mb-4">
          Share your symptoms through our AI-powered chat interface that understands natural language and medical terminology.
        </p>
        
        <ul class="space-y-2 text-left">
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Upload photos or medical documents</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Voice-enabled symptom reporting</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Simple body-map selection tool</span>
          </li>
        </ul>
      </div>
      
      <!-- Step 2: AI Analysis -->
      <div class="bg-white rounded-xl shadow-lg p-8 text-center lg:text-left relative">
        <!-- Step Number -->
        <div class="inline-flex items-center justify-center w-16 h-16 bg-purple-500 text-white rounded-full text-2xl font-bold mb-6 mx-auto lg:mx-0">
          2
        </div>
        
        <h3 class="text-2xl font-bold text-gray-900 mb-4">AI Analysis</h3>
        
        <!-- Image -->
        <div class="mb-6">
          <%= image_tag "marketing/step-ai-analysis.png", class: "w-full h-48 object-cover rounded-lg", alt: "MedGemma AI Analysis" %>
        </div>
        
        <p class="text-gray-600 mb-4">
          Our AI processes your symptoms against millions of medical cases and the latest research for accurate insights.
        </p>
        
        <!-- Accuracy Bar -->
        <div class="mb-4 flex items-center">
          <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-r from-purple-500 to-indigo-500 rounded-full w-[95%]"></div>
          </div>
          <span class="ml-3 text-sm font-medium text-gray-700">95% accuracy</span>
        </div>
        
        <ul class="space-y-2 text-left">
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Personalized risk assessment</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Possible conditions with probabilities</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Treatment recommendations</span>
          </li>
        </ul>
      </div>
      
      <!-- Step 3: Doctor Consultation -->
      <div class="bg-white rounded-xl shadow-lg p-8 text-center lg:text-left relative">
        <!-- Step Number -->
        <div class="inline-flex items-center justify-center w-16 h-16 bg-teal-500 text-white rounded-full text-2xl font-bold mb-6 mx-auto lg:mx-0">
          3
        </div>
        
        <h3 class="text-2xl font-bold text-gray-900 mb-4">Consult with Doctor</h3>
        
        <!-- Image -->
        <div class="mb-6">
          <%= image_tag "marketing/med_consultation.jpg", class: "w-full h-48 object-cover rounded-lg", alt: "MedGemma Doctor Consultation" %>
        </div>
        
        <p class="text-gray-600 mb-4">
          Connect with board-certified physicians who can access your AI assessment and provide personalized care.
        </p>
        
        <!-- Availability Badge -->
        <div class="bg-green-50 rounded-lg p-3 mb-4 flex items-center">
          <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center mr-3">
            <i class="fas fa-clock text-green-600"></i>
          </div>
          <div>
            <p class="text-sm font-medium text-green-800">Available 24/7</p>
            <p class="text-xs text-green-700">Connect with a doctor in minutes</p>
          </div>
        </div>
        
        <ul class="space-y-2 text-left">
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Prescriptions delivered to your door</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Follow-up care coordination</span>
          </li>
          <li class="flex items-center">
            <i class="fas fa-check-circle text-green-500 mr-2"></i>
            <span class="text-gray-700">Specialist referrals when needed</span>
          </li>
        </ul>
      </div>
    
    <!-- Benefits Section -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-blue-50 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-blue-500 text-white rounded-full mx-auto mb-4 flex items-center justify-center">
          <i class="fas fa-bolt"></i>
        </div>
        <h4 class="text-lg font-semibold text-gray-900 mb-2">Speed & Convenience</h4>
        <p class="text-gray-600 text-sm">Get preliminary health insights in seconds, not days or weeks.</p>
      </div>
      
      <div class="bg-purple-50 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-purple-500 text-white rounded-full mx-auto mb-4 flex items-center justify-center">
          <i class="fas fa-lock"></i>
        </div>
        <h4 class="text-lg font-semibold text-gray-900 mb-2">Privacy First</h4>
        <p class="text-gray-600 text-sm">HIPAA compliant with military-grade encryption for all your health data.</p>
      </div>
      
      <div class="bg-teal-50 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-teal-500 text-white rounded-full mx-auto mb-4 flex items-center justify-center">
          <i class="fas fa-chart-line"></i>
        </div>
        <h4 class="text-lg font-semibold text-gray-900 mb-2">Continuous Learning</h4>
        <p class="text-gray-600 text-sm">Our AI improves with every interaction, constantly updated with new research.</p>
      </div>
      
      <div class="bg-amber-50 rounded-xl p-6 text-center">
        <div class="w-12 h-12 bg-amber-500 text-white rounded-full mx-auto mb-4 flex items-center justify-center">
          <i class="fas fa-wallet"></i>
        </div>
        <h4 class="text-lg font-semibold text-gray-900 mb-2">Cost Effective</h4>
        <p class="text-gray-600 text-sm">Save on unnecessary doctor visits and get care at a fraction of traditional costs.</p>
      </div>
    </div>
    
    <!-- Call to Action -->
    <div class="mt-16 text-center">
      <a href="#demo" class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
        <i class="fas fa-play-circle mr-2"></i>
        Try Interactive Demo
      </a>
      <p class="mt-4 text-gray-500">Experience the future of healthcare in just 30 seconds</p>
    </div>
  </div>
</section>
    </div>

    <div class="mt-16 text-center">
      <%= link_to how_it_works_path, class: "inline-flex items-center justify-center px-8 py-4 text-lg font-medium border-2 border-blue-600 text-blue-600 rounded-full hover:bg-blue-600 hover:text-white transition-all duration-300" do %>
        Learn More About Our Process
        <i class="fas fa-arrow-right ml-2"></i>
      <% end %>
    </div>
  </div>
</section>

<!-- Features Grid -->
<section class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
        Everything You Need for
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          Better Health
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Our AI-powered platform brings world-class healthcare to your fingertips
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-transparent hover:border-blue-100">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-500 to-purple-600 opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
            <i class="fas fa-brain text-white text-2xl"></i>
          </div>
          
          <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-700 transition-colors">AI-Powered Diagnosis</h3>
          <p class="text-gray-600 mb-4">
            Get instant, accurate medical assessments powered by Google's MedGemma AI technology with up to 95% accuracy.
          </p>
          
          <a href="/features/ai-diagnostics" class="inline-flex items-center text-blue-600 font-medium group-hover:text-purple-600 transition-colors">
            Learn more
            <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
          </a>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-transparent hover:border-teal-100">
        <div class="absolute inset-0 bg-gradient-to-br from-teal-500 to-green-500 opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 bg-gradient-to-br from-teal-500 to-green-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
            <i class="fas fa-video text-white text-2xl"></i>
