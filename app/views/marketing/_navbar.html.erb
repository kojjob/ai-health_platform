                    <i class="fas fa-home w-5 mr-3 text-blue-600"></i>
                    <span>Dashboard</span>
                  </a>
                <% end %>
                
                <!-- Common user actions -->
                <a href="/account/profile" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 rounded-lg">
                  <i class="fas fa-user-circle w-5 mr-3 text-blue-600"></i>
                  <span>My Profile</span>
                </a>
                <a href="/account/settings" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-700 rounded-lg">
