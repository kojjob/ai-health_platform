<%= content_for :title, "Pricing - MedGemma Health" %>
<%= content_for :meta_description, "Discover MedGemma Health's transparent pricing options for individuals, families, and healthcare providers. Choose from Basic, Professional, or Enterprise plans." %>

<!-- Hero Section -->
<section class="relative pt-32 pb-24 overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-purple-50"></div>
  <div class="absolute top-0 left-0 w-72 h-72 bg-blue-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
  <div class="absolute bottom-0 left-1/2 w-80 h-80 bg-indigo-200 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse" style="animation-delay: 4s;"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-20" data-controller="fade-in">
      <div class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-100 to-purple-100 rounded-full mb-8 shadow-sm border border-blue-200">
        <div class="flex items-center">
          <div class="w-2 h-2 bg-green-400 rounded-full mr-3 animate-pulse"></div>
          <i class="fas fa-shield-alt text-blue-600 mr-2"></i>
          <span class="text-sm font-semibold text-blue-800">HIPAA Compliant & Secure</span>
        </div>
      </div>
      
      <h1 class="text-6xl sm:text-7xl font-black text-gray-900 mb-8 leading-tight invisible-text-fix">
        <span class="block text-gray-900">Healthcare AI</span>
        <span class="bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600 bg-clip-text text-transparent">
          That Fits Your Budget
        </span>
      </h1>
      
      <p class="text-2xl text-gray-600 max-w-4xl mx-auto mb-12 leading-relaxed invisible-text-fix">
        Transparent pricing, powerful AI technology, and proven results. 
        <span class="font-semibold text-gray-800">Join 50,000+ users</span> who trust MedGemma Health.
      </p>

      <!-- Social Proof Stats -->
      <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto mb-12">
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-600 mb-2">99.7%</div>
          <div class="text-sm text-gray-600">Accuracy Rate</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-purple-600 mb-2">50K+</div>
          <div class="text-sm text-gray-600">Active Users</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-indigo-600 mb-2">4.9★</div>
          <div class="text-sm text-gray-600">User Rating</div>
        </div>
      </div>
    </div>

    <!-- Enhanced Free Trial Banner -->
    <div class="max-w-6xl mx-auto mb-16" data-controller="fade-in">
      <div class="relative bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-600 rounded-2xl p-8 shadow-2xl overflow-hidden">
        <!-- Background Pattern -->
        <div class="absolute inset-0 bg-white bg-opacity-5">
          <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
        </div>
        
        <div class="relative flex flex-col lg:flex-row items-center justify-between">
          <div class="text-center lg:text-left mb-6 lg:mb-0">
            <div class="flex items-center justify-center lg:justify-start mb-4">
              <div class="flex items-center bg-white bg-opacity-20 rounded-full px-4 py-2">
                <i class="fas fa-sparkles text-yellow-300 mr-2"></i>
                <span class="text-sm font-bold text-white">LIMITED TIME OFFER</span>
              </div>
            </div>
            <h3 class="text-3xl font-bold text-white mb-3">
              Start Your 14-Day Free Trial Today
            </h3>
            <p class="text-xl text-blue-100 mb-4">
              Experience the full power of MedGemma Health with zero commitment
            </p>
            <div class="flex items-center justify-center lg:justify-start text-blue-100">
              <i class="fas fa-check-circle mr-2"></i>
              <span class="mr-6">No Credit Card</span>
              <i class="fas fa-check-circle mr-2"></i>
              <span class="mr-6">Full Features</span>
              <i class="fas fa-check-circle mr-2"></i>
              <span>Cancel Anytime</span>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#" class="group px-8 py-4 bg-white text-blue-600 rounded-xl font-bold text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
              <span class="flex items-center">
                Start Free Trial
                <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
              </span>
            </a>
            <a href="#pricing-cards" class="px-8 py-4 bg-transparent border-2 border-white text-white rounded-xl font-bold text-lg hover:bg-white hover:text-blue-600 transition-all duration-300">
              View Pricing
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Pricing Section with Enhanced Toggle -->
    <div data-controller="pricing" id="pricing-cards">
      <!-- Enhanced Billing Toggle -->
      <div class="flex flex-col items-center mb-16" data-controller="fade-in">
        <div class="text-center mb-8">
          <h2 class="text-4xl font-bold text-gray-900 mb-4 invisible-text-fix">Choose Your Plan</h2>
          <p class="text-lg text-gray-600 invisible-text-fix">All plans include our core AI technology with a 14-day free trial</p>
        </div>
        
        <div class="flex items-center space-x-6 bg-white rounded-2xl p-2 shadow-lg border border-gray-100">
          <span class="text-gray-700 font-semibold px-4" data-pricing-target="monthlyText">Monthly</span>
          <button 
            type="button" 
            class="relative inline-flex h-12 w-24 items-center rounded-full bg-gradient-to-r from-blue-500 to-purple-500 cursor-pointer shadow-inner"
            data-action="click->pricing#toggle"
            role="switch"
            aria-checked="false"
          >
            <span class="absolute inset-0 flex items-center justify-start pl-1">
              <span 
                data-pricing-target="toggleButton"
                class="h-10 w-10 rounded-full bg-white shadow-lg transform transition-all duration-300 flex items-center justify-center">
                <i class="fas fa-calendar-alt text-gray-600 text-sm"></i>
              </span>
            </span>
          </button>
          <span class="text-gray-700">
            <span data-pricing-target="annualText" class="font-semibold">Annual</span>
            <span class="inline-flex items-center ml-2 px-3 py-1 bg-gradient-to-r from-green-400 to-green-500 text-white text-xs font-bold rounded-full animate-pulse">
              <i class="fas fa-tags mr-1"></i>
              SAVE 20%
            </span>
          </span>
        </div>
      </div>

      <!-- Enhanced Pricing Cards -->
      <div class="pricing-cards grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <% @pricing_plans.each_with_index do |plan, index| %>
        <div 
          class="pricing-card group relative bg-white rounded-3xl shadow-xl border-2 <%= plan[:highlight] ? 'border-purple-500 transform scale-105 lg:scale-110' : 'border-gray-100 hover:border-blue-300' %> transition-all duration-300 hover:shadow-2xl hover:-translate-y-2" 
          data-controller="fade-in"
          data-action="mouseenter->fade-in#pulse"
        >
          <!-- Popular Badge -->
          <% if plan[:badge] %>
            <div class="absolute -top-6 inset-x-0 flex justify-center z-10">
              <div class="flex items-center px-6 py-2 bg-gradient-to-r from-purple-600 via-pink-600 to-purple-600 text-white text-sm font-bold rounded-full shadow-lg animate-pulse">
                <i class="fas fa-crown mr-2 text-yellow-300"></i>
                <%= plan[:badge] %>
                <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
            </div>
          <% end %>
            
          <div class="relative p-8 <%= plan[:highlight] ? 'bg-gradient-to-br from-purple-50 to-blue-50' : '' %> rounded-t-3xl">
            <!-- Plan Header -->
            <div class="text-center mb-8">
              <!-- Plan Icon -->
              <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br <%= plan[:highlight] ? 'from-purple-500 to-blue-500' : 'from-blue-500 to-indigo-500' %> flex items-center justify-center shadow-lg">
                <i class="fas <%= case plan[:name]
                  when 'Basic Care' then 'fa-heart'
                  when 'Professional' then 'fa-user-md'
                  when 'Enterprise' then 'fa-hospital'
                  else 'fa-star'
                end %> text-3xl text-white"></i>
              </div>
              
              <h3 class="text-3xl font-black text-gray-900 mb-3 invisible-text-fix"><%= plan[:name] %></h3>
              <p class="text-gray-600 mb-8 leading-relaxed invisible-text-fix"><%= plan[:description] %></p>
              
              <!-- Enhanced Pricing Display -->
              <div class="mb-8">
                <div data-pricing-target="monthlyPrice" class="transition-all duration-300">
                  <div class="flex items-end justify-center mb-2">
                    <span class="text-6xl font-black text-gray-900 invisible-text-fix">$<%= plan[:monthly_price] %></span>
                    <span class="text-gray-500 ml-2 text-lg font-medium invisible-text-fix">/month</span>
                  </div>
                  <div class="text-sm text-gray-500 invisible-text-fix">Billed monthly</div>
                </div>
                <div data-pricing-target="annualPrice" class="transition-all duration-300 hidden">
                  <div class="flex items-end justify-center mb-2">
                    <span class="text-6xl font-black text-gray-900 invisible-text-fix">$<%= plan[:annual_price] %></span>
                    <span class="text-gray-500 ml-2 text-lg font-medium invisible-text-fix">/month</span>
                  </div>
                  <div class="text-sm text-green-600 font-semibold invisible-text-fix" data-pricing-target="savingsLabel">
                    <i class="fas fa-tags mr-1"></i>
                    Billed annually - Save $<%= (plan[:monthly_price].to_i - plan[:annual_price].to_i) * 12 %>/year
                  </div>
                </div>
              </div>
              
              <!-- Enhanced CTA Button -->
              <%= link_to plan[:cta_text], "#", class: "group block w-full px-8 py-4 text-center #{plan[:highlight] ? 'bg-gradient-to-r from-purple-600 via-pink-600 to-purple-600 text-white shadow-lg shadow-purple-500/25' : 'bg-gradient-to-r from-blue-600 to-indigo-600 text-white shadow-lg shadow-blue-500/25'} rounded-2xl font-bold text-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 relative overflow-hidden" %>
                <span class="relative z-10 flex items-center justify-center">
                  <%= plan[:cta_text] %>
                  <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform duration-300"></i>
                </span>
                <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
              </a>
              
              <!-- Money Back Guarantee -->
              <div class="mt-4 text-sm text-gray-500 flex items-center justify-center">
                <i class="fas fa-shield-check text-green-500 mr-2"></i>
                30-day money-back guarantee
              </div>
            </div>
          </div>

                      <!-- Enhanced Feature List -->
          <div class="border-t border-gray-100 pt-8 px-8">
            <h4 class="text-lg font-bold text-gray-900 mb-6 flex items-center">
              <i class="fas fa-check-circle text-green-500 mr-3"></i>
              What's Included
            </h4>
            <ul class="space-y-4">
              <% plan[:features].each do |feature| %>
                <li class="group flex items-start hover:bg-gray-50 p-2 rounded-lg transition-colors duration-200">
                  <div class="flex-shrink-0 w-6 h-6 bg-gradient-to-r from-green-400 to-green-500 rounded-full flex items-center justify-center mt-0.5 mr-4 group-hover:scale-110 transition-transform duration-200">
                    <i class="fas fa-check text-white text-xs"></i>
                  </div>
                  <span class="text-gray-700 leading-relaxed group-hover:text-gray-900 transition-colors duration-200"><%= feature %></span>
                </li>
              <% end %>
            </ul>
          </div>
          
          <!-- Enhanced Testimonial Card -->
          <div class="mt-8 mx-8 mb-8 p-6 bg-gradient-to-br from-gray-50 to-blue-50 rounded-2xl border border-gray-100 hover:shadow-md transition-all duration-300">
            <div class="flex items-start">
              <div class="flex-shrink-0 mr-4">
                <% if asset_exists?(plan[:testimonial][:avatar]) %>
                  <img src="<%= asset_path(plan[:testimonial][:avatar]) %>" alt="<%= plan[:testimonial][:author] %>" class="w-14 h-14 rounded-full object-cover shadow-lg ring-2 ring-white">
                <% else %>
                  <div class="w-14 h-14 rounded-full flex items-center justify-center bg-gradient-to-br from-blue-500 to-purple-500 text-white shadow-lg ring-2 ring-white">
                    <i class="fas fa-user-circle text-2xl"></i>
                  </div>
                <% end %>
              </div>
              <div class="flex-1">
                <!-- Star Rating -->
                <div class="flex items-center mb-3">
                  <% 5.times do %>
                    <i class="fas fa-star text-yellow-400 text-sm"></i>
                  <% end %>
                  <span class="ml-2 text-xs font-semibold text-gray-600">Verified User</span>
                </div>
                <p class="text-gray-700 text-sm italic mb-3 leading-relaxed">"<%= plan[:testimonial][:quote] %>"</p>
                <div>
                  <p class="text-gray-900 font-bold text-sm"><%= plan[:testimonial][:author] %></p>
                  <p class="text-gray-500 text-xs"><%= plan[:testimonial][:role] %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Enhanced Comparison Table Section -->
<section class="py-24 bg-gradient-to-b from-gray-50 to-white relative overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-100 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-100 to-purple-100 rounded-full mb-6">
        <i class="fas fa-chart-bar text-blue-600 mr-2"></i>
        <span class="text-sm font-bold text-blue-800">DETAILED COMPARISON</span>
      </div>
      <h2 class="text-5xl font-black text-gray-900 mb-6">Compare All Features</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Every plan includes our core AI technology. See exactly what you get with each tier.
      </p>
    </div>
    
    <!-- Enhanced Comparison Table -->
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100" data-controller="fade-in">
      <!-- Sticky Table Header -->
      <div class="overflow-x-auto">
        <table class="w-full min-w-max">
          <thead class="bg-gradient-to-r from-gray-900 to-gray-800 text-white sticky top-0">
            <tr>
              <th class="py-6 px-8 font-bold text-left text-lg">Features</th>
              <th class="py-6 px-6 font-bold text-center text-lg">
                <div class="flex flex-col items-center">
                  <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center mb-2">
                    <i class="fas fa-heart text-white"></i>
                  </div>
                  Basic Care
                </div>
              </th>
              <th class="py-6 px-6 font-bold text-center text-lg bg-gradient-to-r from-purple-600 to-blue-600 relative">
                <div class="flex flex-col items-center">
                  <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center mb-2">
                    <i class="fas fa-user-md text-purple-600"></i>
                  </div>
                  Professional
                  <div class="absolute -top-2 -right-2 bg-yellow-400 text-gray-900 text-xs font-bold px-2 py-1 rounded-full">
                    POPULAR
                  </div>
                </div>
              </th>
              <th class="py-6 px-6 font-bold text-center text-lg">
                <div class="flex flex-col items-center">
                  <div class="w-12 h-12 bg-indigo-500 rounded-xl flex items-center justify-center mb-2">
                    <i class="fas fa-hospital text-white"></i>
                  </div>
                  Enterprise
                </div>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @feature_comparison.each_with_index do |category, cat_index| %>
              <!-- Category Header -->
              <tr class="bg-gradient-to-r from-blue-50 to-purple-50">
                <td colspan="4" class="py-4 px-8">
                  <div class="flex items-center">
                    <div class="w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-500 rounded-lg flex items-center justify-center mr-3">
                      <i class="fas fa-folder text-white text-sm"></i>
                    </div>
                    <span class="font-bold text-gray-900 text-lg"><%= category[:category] %></span>
                  </div>
                </td>
              </tr>
              
              <!-- Category Features -->
              <% category[:features].each_with_index do |feature, feat_index| %>
                <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                  <td class="py-6 px-8 border-r border-gray-100">
                    <div class="font-semibold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors">
                      <%= feature[:name] %>
                    </div>
                    <div class="text-sm text-gray-600 leading-relaxed">
                      <%= feature[:description] %>
                    </div>
                  </td>
                  
                  <!-- Basic Plan Column -->
                  <td class="py-6 px-6 text-center border-r border-gray-100">
                    <% if feature[:basic] == "Not included" %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-gray-100 rounded-full">
                        <i class="fas fa-times text-gray-400"></i>
                      </div>
                    <% else %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-green-100 rounded-full mr-2">
                        <i class="fas fa-check text-green-600"></i>
                      </div>
                      <span class="text-gray-700 font-medium"><%= feature[:basic] %></span>
                    <% end %>
                  </td>
                  
                  <!-- Professional Plan Column (Highlighted) -->
                  <td class="py-6 px-6 text-center bg-gradient-to-br from-purple-50 to-blue-50 border-r border-purple-200">
                    <% if feature[:professional] == "Not included" %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-gray-100 rounded-full">
                        <i class="fas fa-times text-gray-400"></i>
                      </div>
                    <% else %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-purple-100 rounded-full mr-2">
                        <i class="fas fa-check text-purple-600"></i>
                      </div>
                      <span class="text-purple-800 font-bold"><%= feature[:professional] %></span>
                    <% end %>
                  </td>
                  
                  <!-- Enterprise Plan Column -->
                  <td class="py-6 px-6 text-center">
                    <% if feature[:enterprise] == "Not included" %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-gray-100 rounded-full">
                        <i class="fas fa-times text-gray-400"></i>
                      </div>
                    <% else %>
                      <div class="inline-flex items-center justify-center w-8 h-8 bg-indigo-100 rounded-full mr-2">
                        <i class="fas fa-check text-indigo-600"></i>
                      </div>
                      <span class="text-gray-700 font-medium"><%= feature[:enterprise] %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <!-- Call to Action Footer -->
      <div class="bg-gradient-to-r from-gray-900 to-gray-800 p-8">
        <div class="flex flex-col md:flex-row items-center justify-between">
          <div class="text-center md:text-left mb-6 md:mb-0">
            <h3 class="text-2xl font-bold text-white mb-2">Ready to get started?</h3>
            <p class="text-gray-300">Choose your plan and start your free trial today</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#pricing-cards" class="px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl font-bold hover:shadow-lg transform hover:-translate-y-0.5 transition-all duration-300">
              View Plans
            </a>
            <a href="#" class="px-8 py-4 bg-transparent border-2 border-white text-white rounded-xl font-bold hover:bg-white hover:text-gray-900 transition-all duration-300">
              Start Free Trial
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Enhanced Special Offers Section -->
<section class="py-24 bg-gradient-to-br from-purple-900 via-blue-900 to-indigo-900 relative overflow-hidden">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0">
    <div class="absolute top-0 left-0 w-72 h-72 bg-purple-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-blue-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-0 left-1/2 w-80 h-80 bg-indigo-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-pulse" style="animation-delay: 4s;"></div>
  </div>
  
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25px 25px, rgba(255,255,255,0.2) 2px, transparent 0); background-size: 50px 50px;"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-controller="fade-in">
      <div class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full mb-8 shadow-lg">
        <div class="flex items-center">
          <i class="fas fa-fire text-white mr-2 animate-pulse"></i>
          <span class="text-sm font-bold text-white">EXCLUSIVE DISCOUNTS</span>
          <div class="w-2 h-2 bg-yellow-400 rounded-full ml-2 animate-ping"></div>
        </div>
      </div>
      
      <h2 class="text-5xl font-black text-white mb-6">
        Special Pricing for
        <span class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent">
          Heroes in Healthcare
        </span>
      </h2>
      <p class="text-xl text-purple-200 max-w-3xl mx-auto">
        We believe quality healthcare technology should be accessible to everyone making a difference
      </p>
    </div>
    
    <!-- Enhanced Special Offer Cards -->
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      <% @special_offers.each_with_index do |offer, index| %>
        <div class="group relative bg-white rounded-3xl p-8 shadow-2xl border-2 border-purple-200 hover:border-purple-400 transition-all duration-300 hover:shadow-purple-500/25 hover:-translate-y-2" data-controller="fade-in">
          <!-- Offer Icon -->
          <div class="absolute -top-6 left-1/2 transform -translate-x-1/2">
            <div class="w-12 h-12 bg-gradient-to-r <%= case index
              when 0 then 'from-blue-500 to-cyan-500'
              when 1 then 'from-green-500 to-teal-500'
              when 2 then 'from-purple-500 to-pink-500'
            end %> rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
              <i class="fas <%= case index
                when 0 then 'fa-user-md'
                when 1 then 'fa-heart'
