<% content_for :title, "How It Works | MedGemma Health" %>
<% content_for :meta_description, "Learn how MedGemma Health's AI-powered healthcare platform works. From symptoms to treatment in minutes with our three-step process." %>
<% content_for :canonical_url, how_it_works_url %>
<% content_for :open_graph do %>
