<!-- Newsletter Signup Section -->
<section class="py-12 sm:py-20 bg-gradient-to-r from-blue-600 via-purple-600 to-indigo-700 relative overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,<svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" xmlns=\"http://www.w3.org/2000/svg\"><g fill=\"%23ffffff\" fill-opacity=\"0.05\"><polygon points=\"20,0 40,20 20,40 0,20\"/></g></svg>');"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center" data-controller="fade-in">
      <div class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm rounded-full mb-6">
        <i class="fas fa-envelope text-white mr-2"></i>
        <span class="text-sm font-medium text-white">Stay Updated</span>
      </div>
      
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4">
        Subscribe to Our Healthcare Insights
      </h2>
      
      <p class="text-lg text-blue-100 mb-8 max-w-2xl mx-auto">
        Get the latest updates on healthcare technology, AI innovations, and industry best practices delivered to your inbox.
      </p>

      <!-- Newsletter form -->
      <div class="max-w-lg mx-auto" data-controller="fade-in">
        <%= form_with url: newsletter_subscription_path, 
            class: "flex flex-col sm:flex-row gap-4",
            data: { 
              controller: "newsletter-form",
              newsletter_form_target: "form",
              action: "submit->newsletter-form#submit"
            } do |form| %>
          <div class="flex-1">
            <%= form.email_field :email, 
                placeholder: "Enter your email address",
                class: "w-full px-4 py-3 rounded-lg border-2 border-white/20 bg-white/10 backdrop-blur-sm text-white placeholder-white/70 focus:border-white focus:bg-white/20 focus:outline-none transition-all duration-300",
                data: { newsletter_form_target: "email" },
                "aria-label": "Email address for newsletter" %>
          </div>
          <%= form.submit "Subscribe", 
              class: "px-8 py-3 bg-white text-blue-600 rounded-lg font-semibold hover:bg-blue-50 transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 whitespace-nowrap",
              data: { newsletter_form_target: "submit" } %>
        <% end %>
        
        <p class="text-white/80 text-sm mt-4">
          No spam, unsubscribe at any time. Read our 
          <a href="#" class="underline hover:no-underline">Privacy Policy</a>.
        </p>
      </div>

      <!-- Benefits -->
      <div class="grid sm:grid-cols-3 gap-6 mt-12" data-controller="fade-in">
        <% benefits = [
          { icon: "fas fa-brain", title: "AI Insights", description: "Latest AI developments in healthcare" },
          { icon: "fas fa-chart-line", title: "Industry Trends", description: "Market analysis and predictions" },
          { icon: "fas fa-users", title: "Expert Tips", description: "Best practices from healthcare leaders" }
        ] %>

        <% benefits.each do |benefit| %>
          <div class="text-center">
            <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mx-auto mb-3">
              <i class="<%= benefit[:icon] %> text-white"></i>
            </div>
            <h3 class="font-semibold text-white mb-1"><%= benefit[:title] %></h3>
            <p class="text-blue-100 text-sm"><%= benefit[:description] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>